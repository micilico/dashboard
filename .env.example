# Homepage
PUID=1000
PGID=1000
TZ=Europe/Paris
HOMEPAGE_ALLOWED_HOSTS=dashboard.example.com

# qBittorrent widget credentials
HOMEPAGE_VAR_QBITTORRENT_USERNAME=change-me
HOMEPAGE_VAR_QBITTORRENT_PASSWORD=change-me

# Torrent Panel listener
TORRENT_PANEL_PORT=3110

# Prowlarr Panel listener
PROWLARR_PANEL_PORT=3120

# Cloud Panel listener
CLOUD_PANEL_PORT=3130

# Prowlarr widget API key
HOMEPAGE_VAR_PROWLARR_API_KEY=change-me

# Jellyfin widget API key
HOMEPAGE_VAR_JELLYFIN_URL=https://media.example.com
HOMEPAGE_VAR_JELLYFIN_API_KEY=change-me

# Sentry monitoring (optional — leave empty to disable)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
